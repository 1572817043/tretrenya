---
import Head from "@/components/layout/Head.astro";
import type { HeadProps } from "@/types";
import "@/styles/global.css";
import Umami from "@/components/analytics/Umami.astro";
import MusicPlayer from "@/components/blocks/MusicPlayer.astro";
import site from "@/config/site";

type Props = HeadProps;

const head = Astro.props;
---

<html lang={site.meta.lang}>
  <Head {...head} />
  <body
    class="flex min-h-screen items-center justify-center bg-background px-1 py-0.5 font-display text-foreground antialiased selection:bg-primary/20 md:px-2 md:py-1"
  >
    <slot />

    <MusicPlayer />
    <Umami />
  </body>
</html>
