---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import site from "@/config/site";

const friends = (await getCollection("friends")).sort(
  (a, b) => a.data.order - b.data.order,
);

// 按分类分组
const categories = friends.reduce(
  (acc, friend) => {
    const cat = friend.data.category || "其他";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(friend);
    return acc;
  },
  {} as Record<string, typeof friends>,
);

// 分类顺序
const categoryOrder = [
  "AI工具",
  "影视",
  "磁力资源",
  "音乐",
  "书籍",
  "搜索引擎",
  "资源",
  "工具",
  "其他",
];
const sortedCategories = categoryOrder.filter((cat) => categories[cat]);
---

<Layout
  title={site.labels.friendsTitle}
  description={site.labels.friendsDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-4xl p-8 duration-700 md:p-16"
  >
    <header class="mb-12">
      <h2 class="mb-4 text-3xl font-bold">{site.labels.friendsTitle}</h2>
      <p class="mb-12 text-sm font-light text-muted-foreground italic">
        {site.labels.friendsDescription}
      </p>
    </header>

    {
      sortedCategories.map((category) => (
        <section class="mb-10">
          <h3 class="mb-4 text-xs font-bold tracking-widest text-primary uppercase">
            {category}
          </h3>
          <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
            {categories[category].map((friend) => (
              <a
                href={friend.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 rounded-xl border border-border/40 p-3 transition-all duration-300 hover:bg-muted/30"
              >
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <span class="text-xs font-bold">
                    {friend.data.name.charAt(0)}
                  </span>
                </div>
                <div class="min-w-0 flex-1">
                  <span class="text-sm font-bold text-foreground/80 group-hover:text-primary">
                    {friend.data.name}
                  </span>
                  <p class="line-clamp-1 text-[11px] text-muted-foreground">
                    {friend.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>
