---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="音乐" description="个人最喜欢的歌曲">
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-4xl p-8 duration-700 md:p-16"
  >
    <header class="mb-12">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">音乐</h2>
      <p class="text-sm font-light text-muted-foreground italic">
        个人最喜欢的歌曲。
      </p>
    </header>

    <div class="py-12 text-center">
      <p class="text-sm text-muted-foreground">暂无歌曲，敬请期待</p>
    </div>
  </div>
</Layout>
